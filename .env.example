# Planning Center Credentials
# Get these from: https://api.planningcenteronline.com/oauth/applications
PLANNING_CENTER_APP_ID=your_app_id_here
PLANNING_CENTER_SECRET=your_secret_here

# Craft Docs API Token
# Get this from: Craft Settings > Integrations > API
CRAFT_API_TOKEN=your_craft_token_here

# Claude API Key
# Get this from: https://console.anthropic.com/
CLAUDE_API_KEY=your_claude_api_key_here

# Optional: Specify Claude model (defaults to claude-sonnet-4-5-20250929)
# CLAUDE_MODEL=claude-sonnet-4-5-20250929
